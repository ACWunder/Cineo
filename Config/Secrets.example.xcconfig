// Cineo — Secrets (example)
//
// Duplicate this file as `Secrets.xcconfig` (same folder) and fill in your
// TMDB v4 Read Access Token (Bearer). `Secrets.xcconfig` is gitignored.
//
// Get your token at https://www.themoviedb.org/settings/api → "API Read Access Token"

// Slashes are escaped to prevent xcconfig comment-parsing of `//` inside values.
TMDB_BEARER_TOKEN = REPLACE_WITH_YOUR_TMDB_V4_BEARER_TOKEN

// Wired into Info.plist at build-time via $(TMDB_BEARER_TOKEN).
// Do not commit a real token.
